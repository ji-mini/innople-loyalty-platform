{
  "name": "customer-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:innople": "dotenv -e .env.innople -- expo start -c --lan",
    "start:innople:tunnel": "dotenv -e .env.innople -- expo start -c --tunnel",
    "web:innople": "dotenv -e .env.innople.web -- expo start -c --web",
    "start:retail": "dotenv -e .env.retail -- expo start -c --lan",
    "start:retail:tunnel": "dotenv -e .env.retail -- expo start -c --tunnel",
    "start:fashion": "dotenv -e .env.fashion -- expo start -c --lan",
    "start:fashion:tunnel": "dotenv -e .env.fashion -- expo start -c --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "expo": "~54.0.34",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "jsbarcode": "^3.12.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
